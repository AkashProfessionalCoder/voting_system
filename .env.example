# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/flutter_chennai_voting

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production

# Email (Gmail App Password)
EMAIL_USER=your_email@gmail.com
